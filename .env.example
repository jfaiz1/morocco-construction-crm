# Environment Configuration for WhatsApp Invoice CRM

# Node Environment
NODE_ENV=development
PORT=3001

# ===== FIREBASE / FIRESTORE =====
# Download service account JSON from Firebase Console
# Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ===== TWILIO (WhatsApp) =====
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=whatsapp:+14155552671

# Webhook URL (where Twilio sends messages)
WEBHOOK_URL=https://your-domain.com/api/whatsapp/webhook

# Skip Twilio signature verification (false in production)
VERIFY_TWILIO_SIGNATURE=false

# ===== CLAUDE API (Vision + Text) =====
# Get from https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ===== DEEPGRAM API (Audio Transcription) =====
# Get from https://www.deepgram.com (free: 300 min/month)
DEEPGRAM_API_KEY=your_deepgram_key_here
