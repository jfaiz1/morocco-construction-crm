{
  "name": "morocco-whatsapp-crm",
  "version": "1.0.0",
  "description": "WhatsApp CRM for Invoice Automation - Morocco Construction",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
